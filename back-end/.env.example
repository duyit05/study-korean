# ==============================================
# FILE NÀY CHỈ LÀ MẪU (template) - COMMIT được
# Tạo file .env thật từ file này, KHÔNG commit .env
# ==============================================

# ---- Database PostgreSQL ----
DB_URL=jdbc:postgresql://localhost:5432/study_korean
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JPA / Hibernate ----
# dev: update | prod: validate hoặc none
DDL_AUTO=update
SHOW_SQL=true

# ---- JWT ----
# Sinh bằng: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_SECRET_REFRESH_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRY_TIME=1
JWT_EXPIRY_DAY=14

# ---- MinIO ----
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# ---- Cloudflare R2 ----
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=CHANGE_ME
R2_SECRET_KEY=CHANGE_ME
R2_BUCKET=korean-learning-files
R2_REGION=auto

# ---- CORS ----
# Các origin được phép (phân cách bằng dấu phẩy nếu có nhiều)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Swagger/OpenAPI ----
# true = bật (dev), false = tắt (prod)
SWAGGER_ENABLED=true
